{
  "name": "image-processing-server",
  "version": "1.0.0",
  "description": "API para receber capturas da ESP32-CAM, detectar mudancas entre imagens e enviar alertas.",
  "main": "dist/server.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit"
